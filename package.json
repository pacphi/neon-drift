{
  "name": "neon-drift",
  "version": "0.1.0",
  "description": "A browser-based 3D synthwave kart racer (Three.js + Vite).",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=26",
    "pnpm": ">=11"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit": "pnpm audit",
    "audit:fix": "pnpm audit --fix",
    "deps:outdated": "pnpm outdated",
    "deps:update": "pnpm update",
    "deps:update:latest": "pnpm update --latest",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run test",
    "fix": "pnpm run lint:fix && pnpm run format"
  },
  "dependencies": {
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/three": "^0.184.1",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
